{
  "name": "@codesema/contract",
  "version": "0.3.0",
  "description": "Shared review contract (types + sanitizers) between the codesema CLI and codesema.com.",
  "license": "MIT",
  "author": "Hasan TASKIN",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getCodesema/codesema-cli.git",
    "directory": "packages/contract"
  },
  "keywords": ["code-review", "codesema", "contract"],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": { "node": ">=20" },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsdown": "^0.22.5",
    "typescript": "^6.0.3"
  }
}
