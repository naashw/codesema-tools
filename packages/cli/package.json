{
  "name": "codesema",
  "version": "0.5.0",
  "description": "Local merge request review, step by step. Your AI agent reviews, codesema displays.",
  "license": "MIT",
  "author": "Hasan TASKIN",
  "keywords": [
    "code-review",
    "merge-request",
    "pull-request",
    "ai",
    "agent",
    "cli",
    "git",
    "diff"
  ],
  "type": "module",
  "bin": {
    "codesema": "dist/index.mjs"
  },
  "files": [
    "dist",
    "web-dist"
  ],
  "scripts": {
    "build": "tsdown && node scripts/embed-web.mjs",
    "typecheck": "tsc --noEmit",
    "prepack": "node scripts/prepack.mjs",
    "prepublishOnly": "npm run build --prefix ../contract && npm run build --prefix ../web && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "codesema-contract": "workspace:*",
    "tsdown": "^0.22.5",
    "typescript": "^6.0.3"
  }
}
