{
  "name": "mr-review",
  "version": "0.1.0",
  "description": "Local merge request review, told as chapters. Your AI agent reviews, mr-review displays.",
  "license": "MIT",
  "author": "Hasan TASKIN",
  "keywords": [
    "code-review",
    "merge-request",
    "pull-request",
    "ai",
    "agent",
    "cli",
    "git",
    "diff"
  ],
  "type": "module",
  "bin": {
    "mr-review": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "web-dist"
  ],
  "scripts": {
    "build": "tsdown && node scripts/embed-web.mjs",
    "typecheck": "tsc --noEmit",
    "prepack": "node scripts/prepack.mjs",
    "prepublishOnly": "npm run build --prefix ../web && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "hono": "^4.12.28"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsdown": "^0.22.4",
    "typescript": "^6.0.3"
  }
}
